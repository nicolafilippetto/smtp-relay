# =============================================================================
# SMTP Relay — Environment template
# =============================================================================
# Copy this file to `.env` and fill in the values.
# DO NOT commit the resulting `.env` to any VCS.
#
# Two categories of secrets live here:
#   (1) Infrastructure secrets (mandatory before first start)
#   (2) Operational knobs (optional, all have safe defaults)
#
# Application secrets (Entra ID client_id/secret, SMTP account passwords,
# UI admin credentials) are NOT configured here — they are inserted through
# the UI after the first boot. See README.md.
# =============================================================================

# -----------------------------------------------------------------------------
# (1) Infrastructure secrets — required
# -----------------------------------------------------------------------------

# Fernet key used to encrypt application secrets at rest in the DB.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NEVER change this value after data has been stored: encrypted rows
# become unreadable and must be re-entered through the UI.
ENCRYPTION_KEY=

# Secret used to sign session cookies and CSRF tokens.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# -----------------------------------------------------------------------------
# (2) Operational knobs — optional
# -----------------------------------------------------------------------------

# UI display name (used in TOTP issuer and page titles).
APP_NAME=SMTP Relay

# Session lifetime in hours. After this the user must log in again.
SESSION_LIFETIME_HOURS=8

# UI login ban policy.
UI_LOGIN_BAN_THRESHOLD=5
UI_LOGIN_BAN_DURATION_MIN=30

# SMTP listener binding. The container listens on 0.0.0.0:2525 internally;
# these two values control only how the host port maps to it.
# Keep SMTP_BIND_HOST=127.0.0.1 if you reach the relay via a loopback tunnel,
# or bind it to a specific LAN interface. See README -> Hardening.
SMTP_BIND_HOST=0.0.0.0
SMTP_BIND_PORT=2525

# Maximum inbound message size (bytes). 30 MiB by default.
SMTP_MAX_MESSAGE_SIZE=31457280

# Nginx bindings (HTTPS is mandatory; HTTP simply redirects to HTTPS).
HTTP_BIND_HOST=0.0.0.0
HTTP_PORT=80
HTTPS_BIND_HOST=0.0.0.0
HTTPS_PORT=443

# -----------------------------------------------------------------------------
# Admin reset — only set these when you need to reset the admin password.
# Procedure:
#   1. Set ADMIN_RESET=1 and ADMIN_NEW_PASSWORD=<new password>
#   2. docker compose up -d ui
#   3. Log in once, re-enroll TOTP
#   4. Unset BOTH variables and restart the stack:
#      ADMIN_RESET=0
#      ADMIN_NEW_PASSWORD=
#      docker compose up -d
# -----------------------------------------------------------------------------
ADMIN_RESET=0
ADMIN_NEW_PASSWORD=
